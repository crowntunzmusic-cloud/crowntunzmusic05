# ──────────────────────────────────────────────────────────────
# Crowntunz Music — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# For Cloudflare Pages deployment, add these in:
#   Cloudflare Dashboard → Workers & Pages → crowntunz-music → Settings → Environment Variables
#
# For Netlify deployment, add these in:
#   Netlify Dashboard → Site Settings → Environment Variables
#
# For GitHub Actions, add these as repository secrets in:
#   GitHub Repo → Settings → Secrets and Variables → Actions
#
# NEVER commit your actual .env or .env.local file.
# ──────────────────────────────────────────────────────────────


# === Supabase (REQUIRED) ===
# Your Supabase project URL — found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon public key — safe for client-side (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER ONLY, never expose to the client
# Used for admin operations and migrations
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase database connection string (server-side only, for migrations/scripts)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres


# === Cloudflare R2 — Media Storage (REQUIRED for uploads) ===
# Public base URL for serving R2 assets to the browser
# Use the R2 bucket public URL or a custom domain you've configured
NEXT_PUBLIC_CLOUDFLARE_R2_URL=https://your-r2-bucket.r2.dev

# R2 API credentials — SERVER ONLY, used for S3-compatible uploads
# Found in Cloudflare Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=crowntunz-music
CLOUDFLARE_R2_REGION=auto


# === GitHub Actions — Cloudflare Pages Deploy Secrets ===
# Create API token at: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Use the "Edit Cloudflare Workers" template, scoped to your account + Pages project
CLOUDFLARE_API_TOKEN=

# Account ID — found in Cloudflare Dashboard sidebar (right side of any page)
CLOUDFLARE_ACCOUNT_ID=


# === GitHub Actions — Netlify Deploy Secrets (only if using Netlify) ===
# Netlify personal access token — create at:
#   Netlify Dashboard → User Settings → Applications → Personal Access Tokens
NETLIFY_AUTH_TOKEN=

# Netlify site ID — found in:
#   Netlify Dashboard → Site Settings → General → Site Details → API ID
NETLIFY_SITE_ID=


# === Optional ===
# Analytics tracking ID (e.g. Google Analytics, Plausible)
NEXT_PUBLIC_ANALYTICS_ID=

# Disable Next.js telemetry (set to 1 to disable)
NEXT_TELEMETRY_DISABLED=1
